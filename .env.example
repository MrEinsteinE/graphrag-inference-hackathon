# OpenAI-compatible chat (Groq — get a key at https://console.groq.com/)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
CHAT_MODEL=llama-3.3-70b-versatile

# Alternative: OpenAI
# OPENAI_BASE_URL=https://api.openai.com/v1
# CHAT_MODEL=gpt-4o-mini

# Embedding API (optional — Basic RAG uses local MiniLM if unset)
EMBEDDING_MODEL=

# Hugging Face (LLM-as-judge on Inference API — optional)
HF_JUDGE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
HUGGINGFACEHUB_API_TOKEN=

# TigerGraph / GraphRAG (Pipeline 3)
TIGERGRAPH_HOST=http://127.0.0.1
TIGERGRAPH_USERNAME=tigergraph
TIGERGRAPH_PASSWORD=tigergraph
TIGERGRAPH_GRAPHNAME=TigerGraphRAG
TIGERGRAPH_GS_PORT=14240
TIGERGRAPH_RESTPP_PORT=14240
GRAPHRAG_HOST=http://127.0.0.1:8000
GRAPHRAG_SEARCH_METHOD=hybrid

# Cost estimate (USD per 1M tokens) — set from your provider; Groq is low/zero for free tier
PRICE_PROMPT_PER_MTOK=0.05
PRICE_COMPLETION_PER_MTOK=0.08

# Optional: cap Basic RAG index size for faster dev (omit or 0 = index full corpus)
# BENCHMARK_BASIC_RAG_MAX_CHUNKS=2500

# Local embeddings (Basic RAG MiniLM) + BERTScore: auto | cuda | mps | cpu
# BENCHMARK_EMBED_DEVICE=auto
